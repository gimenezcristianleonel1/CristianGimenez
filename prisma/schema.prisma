// ============================================================
//  Livestock Management System - Prisma Schema (Paso 2)
// ------------------------------------------------------------
//  Principios de diseño aplicados:
//   * Series temporales / inmutabilidad: WeightHistory, HealthRecord
//     y AnimalMovement son tablas append-only (insert + timestamp).
//   * Enums estrictos: estados, especies, tipos de evento y de medicación
//     se modelan como enums para evitar datos ruidosos (Data Readiness IA).
//   * Enriquecimiento: cada tabla principal expone `metadata Json` (JSONB)
//     para datos ambientales / de sensores futuros sin romper el esquema.
//   * Outbox transaccional: OutboxEvent persiste los Domain Events en la
//     misma transacción del cambio de estado (EDA escalable a brokers/IoT/ML).
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
//  Enums (estandarización de datos)
// ------------------------------------------------------------

enum Species {
  BOVINE
  PORCINE
  OVINE
  CAPRINE
  EQUINE
  OTHER
}

enum Sex {
  MALE
  FEMALE
}

/// Ciclo de vida del animal. READY_FOR_SALE es un estado explícito para que
/// las reglas de carencia puedan bloquear la transición a venta.
enum AnimalStatus {
  ACTIVE
  QUARANTINE
  READY_FOR_SALE
  SOLD
  DECEASED
}

enum LocationType {
  PASTURE // Potrero
  PEN // Corral
  CORRAL
  BARN // Establo
  QUARANTINE_AREA
  PADDOCK // Lote
}

enum HealthEventType {
  VACCINATION
  DEWORMING
  TREATMENT
  SURGERY
  CHECKUP
  OTHER
}

/// Origen del dato de pesaje: prepara la ingesta desde básculas / IoT.
enum WeightSource {
  MANUAL
  SCALE
  IOT_SENSOR
  ESTIMATED
}

enum MovementReason {
  ROTATION // Rotación de pastura
  OVERGRAZING_PREVENTION // Evitar sobrepastoreo
  MEDICAL // Aislamiento / tratamiento
  WEANING // Destete
  SALE_PREPARATION
  REGROUPING
  OTHER
}

enum OutboxStatus {
  PENDING
  PROCESSED
  FAILED
}

enum TaskStatus {
  PENDING
  COMPLETED
}

/// Tipo de trabajo de diagnóstico reproductivo en la manga.
enum CheckType {
  TACTO
  ECOGRAFIA
}

/// Resultado del diagnóstico. El valor de BD conserva el acento ("PREÑADA");
/// el identificador del cliente es ASCII (PRENADA) por límite de Prisma.
enum PregnancyStatus {
  PRENADA @map("PREÑADA")
  VACIA
}

// ------------------------------------------------------------
//  User (identidad - "Sign in with Google")
// ------------------------------------------------------------

model User {
  id       String  @id @default(uuid()) @db.Uuid
  /// Identificador estable de Google (claim `sub`). Opcional: los usuarios
  /// pueden registrarse con email + contraseña en lugar de Google.
  googleId String? @unique @map("google_id")
  email    String  @unique
  name     String?
  picture  String?
  /// Hash bcrypt de la contraseña (solo para usuarios de email/contraseña).
  passwordHash String? @map("password_hash")

  metadata Json @default("{}") @db.JsonB

  /// Establecimientos de los que el usuario es dueño.
  establishments Establishment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ------------------------------------------------------------
//  Establishment (Establecimiento / Finca / Empresa ganadera)
//  Raíz de multi-tenancy: todos los datos cuelgan de un establecimiento.
// ------------------------------------------------------------

model Establishment {
  id      String  @id @default(uuid()) @db.Uuid
  name    String
  country String?

  metadata Json @default("{}") @db.JsonB

  /// Dueño del establecimiento (clave foránea al usuario autenticado).
  ownerId String @map("owner_id") @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  animals         Animal[]
  locations       Location[]
  importTemplates ImportTemplate[]
  tasks           Task[]
  reproductiveChecks ReproductiveCheck[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ownerId])
  @@map("establishments")
}

// ------------------------------------------------------------
//  Task (Planificación y tareas del campo)
// ------------------------------------------------------------

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  /// Fecha límite de la tarea (para el cálculo de "próximas a vencer").
  dueDate     DateTime?  @map("due_date")
  /// Fecha de finalización (se setea al pasar a COMPLETED).
  completedAt DateTime?  @map("completed_at")

  establishmentId String        @map("establishment_id") @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([establishmentId])
  @@map("tasks")
}

// ------------------------------------------------------------
//  ImportTemplate (aprendizaje de mapeos de columnas por establecimiento)
// ------------------------------------------------------------

model ImportTemplate {
  id String @id @default(uuid()) @db.Uuid

  establishmentId String        @map("establishment_id") @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  /// Firma normalizada de los encabezados del archivo (para reconocer la misma
  /// estructura la próxima vez y mapear automáticamente).
  signature String
  name      String?
  /// Mapeo { campoApp: "Encabezado del Excel" }, p.ej. { tagId: "N° Caravana" }.
  mapping   Json @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([establishmentId, signature])
  @@index([establishmentId])
  @@map("import_templates")
}

// ------------------------------------------------------------
//  Animal (agregado raíz de trazabilidad)
// ------------------------------------------------------------

model Animal {
  id     String       @id @default(uuid()) @db.Uuid

  /// Establecimiento dueño del animal (multi-tenancy).
  establishmentId String        @map("establishment_id") @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  /// Caravana / Arete: único POR establecimiento.
  tagId  String       @map("tag_id")
  species Species
  breed  String
  sex    Sex
  birthDate      DateTime @map("birth_date") @db.Date
  /// Peso al alta (kg). El histórico vive en WeightHistory.
  initialWeightKg Decimal @map("initial_weight_kg") @db.Decimal(7, 2)
  status AnimalStatus @default(ACTIVE)

  // Genealogía (auto-relaciones opcionales)
  motherId String? @map("mother_id") @db.Uuid
  mother   Animal? @relation("Maternity", fields: [motherId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  offspringAsMother Animal[] @relation("Maternity")

  fatherId String? @map("father_id") @db.Uuid
  father   Animal? @relation("Paternity", fields: [fatherId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  offspringAsFather Animal[] @relation("Paternity")

  // Ubicación actual (desnormalizada para consultas rápidas)
  currentLocationId String?   @map("current_location_id") @db.Uuid
  currentLocation   Location? @relation("CurrentResidents", fields: [currentLocationId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  /// Metadatos de enriquecimiento (JSONB): genética, origen, sensores, etc.
  metadata Json @default("{}") @db.JsonB

  weightHistory WeightHistory[]
  healthRecords HealthRecord[]
  movements     AnimalMovement[]
  photo         AnimalPhoto?
  reproductiveChecks ReproductiveCheck[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([establishmentId, tagId])
  @@index([establishmentId])
  @@index([status])
  @@index([species])
  @@index([currentLocationId])
  @@index([motherId])
  @@index([fatherId])
  @@map("animals")
}

// ------------------------------------------------------------
//  WeightHistory (serie temporal inmutable / append-only)
// ------------------------------------------------------------

model WeightHistory {
  id       String @id @default(uuid()) @db.Uuid
  animalId String @map("animal_id") @db.Uuid
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  weightKg Decimal @map("weight_kg") @db.Decimal(7, 2)
  /// Momento real del pesaje (clave de la serie temporal).
  measuredAt DateTime @map("measured_at")
  source     WeightSource @default(MANUAL)

  /// Variables ambientales / lecturas de sensor en el momento del pesaje.
  metadata Json @default("{}") @db.JsonB

  /// Solo timestamp de inserción; los registros nunca se actualizan.
  createdAt DateTime @default(now()) @map("created_at")

  @@index([animalId, measuredAt])
  @@map("weight_history")
}

// ------------------------------------------------------------
//  HealthRecord (serie temporal inmutable / append-only)
// ------------------------------------------------------------

model HealthRecord {
  id       String @id @default(uuid()) @db.Uuid
  animalId String @map("animal_id") @db.Uuid
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  eventType  HealthEventType @map("event_type")
  medication String?
  dosage     String?
  appliedAt  DateTime        @map("applied_at")

  /// Período de carencia en días (tiempo de espera antes de consumo).
  withdrawalDays Int @default(0) @map("withdrawal_days")
  /// Fecha hasta la que el animal NO puede ir a consumo/venta.
  /// Se calcula en el servicio (appliedAt + withdrawalDays) y se persiste
  /// para consultas eficientes de "listo para venta".
  withdrawalUntil DateTime? @map("withdrawal_until")

  notes String?

  /// Diagnóstico estructurado / lecturas adicionales (JSONB).
  metadata Json @default("{}") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  @@index([animalId, appliedAt])
  @@index([withdrawalUntil])
  @@index([eventType])
  @@map("health_records")
}

// ------------------------------------------------------------
//  Location (Potreros / Corrales / Lotes)
// ------------------------------------------------------------

model Location {
  id   String       @id @default(uuid()) @db.Uuid

  /// Establecimiento dueño de la ubicación (multi-tenancy).
  establishmentId String        @map("establishment_id") @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  /// Nombre único POR establecimiento.
  name String
  type LocationType

  /// Capacidad máxima de animales (control de sobrepastoreo).
  capacity     Int?
  areaHectares Decimal? @map("area_hectares") @db.Decimal(8, 2)
  description  String?

  metadata Json @default("{}") @db.JsonB

  currentResidents Animal[]         @relation("CurrentResidents")
  movementsFrom    AnimalMovement[] @relation("MovementFrom")
  movementsTo      AnimalMovement[] @relation("MovementTo")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([establishmentId, name])
  @@index([establishmentId])
  @@index([type])
  @@map("locations")
}

// ------------------------------------------------------------
//  AnimalMovement (serie temporal inmutable de traslados)
// ------------------------------------------------------------

model AnimalMovement {
  id       String @id @default(uuid()) @db.Uuid
  animalId String @map("animal_id") @db.Uuid
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  fromLocationId String?   @map("from_location_id") @db.Uuid
  fromLocation   Location? @relation("MovementFrom", fields: [fromLocationId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  toLocationId String   @map("to_location_id") @db.Uuid
  toLocation   Location @relation("MovementTo", fields: [toLocationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  reason  MovementReason?
  movedAt DateTime        @map("moved_at")
  notes   String?

  metadata Json @default("{}") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  @@index([animalId, movedAt])
  @@index([toLocationId])
  @@map("animal_movements")
}

// ------------------------------------------------------------
//  AnimalPhoto (foto del animal - una por animal, upsert)
// ------------------------------------------------------------

model AnimalPhoto {
  id       String @id @default(uuid()) @db.Uuid
  animalId String @unique @map("animal_id") @db.Uuid
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  mimeType String  @map("mime_type")
  filename String?
  /// Bytes de la imagen (bytea). Para producción a gran escala conviene mover
  /// esto a almacenamiento de objetos (S3/Cloudinary) y guardar sólo la URL.
  data     Bytes

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("animal_photos")
}

// ------------------------------------------------------------
//  OutboxEvent (Patrón Outbox transaccional para Domain Events)
// ------------------------------------------------------------

model OutboxEvent {
  id            String       @id @default(uuid()) @db.Uuid
  /// Id único de la ocurrencia del evento (idempotencia en consumidores).
  eventId       String       @unique @map("event_id") @db.Uuid
  eventName     String       @map("event_name")
  aggregateType String       @map("aggregate_type")
  aggregateId   String       @map("aggregate_id")
  payload       Json         @db.JsonB
  status        OutboxStatus @default(PENDING)
  occurredAt    DateTime     @map("occurred_at")
  processedAt   DateTime?    @map("processed_at")
  attempts      Int          @default(0)
  error         String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, occurredAt])
  @@map("outbox_events")
}

// ------------------------------------------------------------
//  ReproductiveCheck (diagnóstico de tacto / ecografía en la manga)
// ------------------------------------------------------------

model ReproductiveCheck {
  id     String          @id @default(uuid()) @db.Uuid
  date   DateTime        @default(now())
  type   CheckType
  result PregnancyStatus
  observations String?

  /// Animal controlado.
  animalId String @map("animal_id") @db.Uuid
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  /// Potrero donde se encontraba el lote al momento del trabajo.
  potreroId String @map("potrero_id") @db.Uuid

  /// Establecimiento dueño del registro (multi-tenancy).
  establishmentId String        @map("establishment_id") @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([establishmentId])
  @@index([potreroId])
  @@index([animalId])
  @@map("reproductive_checks")
}

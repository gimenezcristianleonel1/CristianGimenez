# ============================================================
#  Livestock Management API - Environment Variables
#  Copy this file to `.env` and adjust the values.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# --- PostgreSQL / Prisma ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://ganadero:ganadero@localhost:5432/livestock?schema=public

# Individual parts (used by docker-compose for local development)
POSTGRES_USER=ganadero
POSTGRES_PASSWORD=ganadero
POSTGRES_DB=livestock
POSTGRES_PORT=5432

# --- Swagger ---
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

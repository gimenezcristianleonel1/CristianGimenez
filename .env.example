# ============================================================
#  Livestock Management API - Environment Variables
#  Copy this file to `.env` and adjust the values.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
# CORS: '*' o lista separada por comas (ej. http://localhost:5173)
CORS_ORIGIN=*

# --- PostgreSQL / Prisma ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://ganadero:ganadero@localhost:5432/livestock?schema=public

# Individual parts (used by docker-compose for local development)
POSTGRES_USER=ganadero
POSTGRES_PASSWORD=ganadero
POSTGRES_DB=livestock
POSTGRES_PORT=5432

# --- Swagger ---
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# --- Autenticación (Sign in with Google) ---
# Obtené estas credenciales en https://console.cloud.google.com/apis/credentials
# Creá un "OAuth 2.0 Client ID" de tipo "Web application".
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
# Secreto para firmar los JWT propios (cambialo en producción por uno largo y aleatorio).
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Duración del token (largo para uso offline en el campo).
JWT_EXPIRES_IN=30d

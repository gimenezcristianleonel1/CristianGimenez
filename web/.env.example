# URL base de la API (incluye el prefijo). Para producción, apuntá a tu backend.
VITE_API_URL=http://localhost:3000/api/v1

# Client ID de Google OAuth (tipo "Web application").
# Obtenelo en https://console.cloud.google.com/apis/credentials y agregá el
# origen de la app (ej. http://localhost:5173) a "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
